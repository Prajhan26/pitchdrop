# Privy — https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=

# Privy App Secret — server-side only (never expose to client)
# PRIVY_APP_SECRET=

# Indexer API (Story 1.5)
NEXT_PUBLIC_INDEXER_URL=http://localhost:3001

# Deployed contract addresses — leave blank until Deploy.s.sol has been run (Story 1.6)
# On-chain voting and idea registration are skipped when these are unset.
NEXT_PUBLIC_IDEA_REGISTRY_ADDRESS=
NEXT_PUBLIC_VOTING_ENGINE_ADDRESS=

# Geo-blocking (Story 1.3)
# Set to "true" in local dev to test Cloudflare geo-blocking middleware.
# In production this is always active; the CF-IPCountry header is set by Cloudflare.
# GEO_BLOCK_ENABLED=true
