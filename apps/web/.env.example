# Privy — https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=

# Privy App Secret — server-side only (never expose to client)
# PRIVY_APP_SECRET=

# Geo-blocking (Story 1.3)
# Set to "true" in local dev to test Cloudflare geo-blocking middleware.
# In production this is always active; the CF-IPCountry header is set by Cloudflare.
# GEO_BLOCK_ENABLED=true
