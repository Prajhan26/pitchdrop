# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/pitchdrop

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ── Chain ─────────────────────────────────────────────────────────────────────
# "base" for mainnet, anything else defaults to Base Sepolia
CHAIN=base-sepolia
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── Core contracts (Story 1.6) ────────────────────────────────────────────────
# Leave blank to disable on-chain event indexing
IDEA_REGISTRY_ADDRESS=
VOTING_ENGINE_ADDRESS=

# Block to start indexing from (set to deployment tx block to skip history)
INDEX_FROM_BLOCK=0

# ── Resolution engine (Story 1.8) ────────────────────────────────────────────
# Private key of IdeaRegistry owner. When unset, DB is updated but no on-chain tx.
RESOLVER_PRIVATE_KEY=

# ── Reputation minter (Story 7.2) ────────────────────────────────────────────
# ReputationRegistry contract address and owner private key
REPUTATION_REGISTRY_ADDRESS=
REPUTATION_MINTER_PRIVATE_KEY=

# ── Airdrop Merkle generator (Story 5.2) ─────────────────────────────────────
# AirdropDistributor contract address and owner private key
AIRDROP_DISTRIBUTOR_ADDRESS=
AIRDROP_OWNER_PRIVATE_KEY=

# ── Sovereign Agent (Story 8.1) ───────────────────────────────────────────────
SOVEREIGN_AGENT_ADDRESS=
