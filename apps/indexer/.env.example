DATABASE_URL=postgresql://user:password@localhost:5432/pitchdrop
PORT=3001
CORS_ORIGIN=http://localhost:3000

# ── Event indexer (Story 1.7) ────────────────────────────────────────────────
# Deployed contract addresses — leave blank to disable event indexer
IDEA_REGISTRY_ADDRESS=
VOTING_ENGINE_ADDRESS=

# Chain: "base" for mainnet, anything else defaults to Base Sepolia
CHAIN=base-sepolia

BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Block number to start indexing from (set to deployment tx block to skip history)
INDEX_FROM_BLOCK=0

# ── Resolution engine (Story 1.8) ────────────────────────────────────────────
# Private key of the IdeaRegistry owner account (typically same as deployer).
# When unset, resolution still runs but only updates the DB (no on-chain tx).
RESOLVER_PRIVATE_KEY=
