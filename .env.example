# pitchdrop — root environment variables example
# Copy to .env.local in each app — never commit .env files

# ─── Blockchain ───────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASESCAN_API_KEY=

# ─── Wallet / Auth ────────────────────────────────────
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ─── EigenCloud (Sovereign Agent) ─────────────────────
EIGENCLOUD_API_KEY=

# ─── AI (via EigenCloud TEE) ──────────────────────────
ANTHROPIC_API_KEY=

# ─── Compliance ───────────────────────────────────────
TRM_LABS_API_KEY=

# ─── Database (Railway) ───────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/pitchdrop

# ─── Cache (Upstash Redis) ────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Monitoring ───────────────────────────────────────
SENTRY_DSN=

# ─── ERC-4337 Paymaster ───────────────────────────────
PAYMASTER_ADDRESS=
BUNDLER_URL=
